#!/bin/bash
# ccvm - Launch Claude Code in a Lima VM with Docker support.
# bypassPermissions is safe here because the VM provides host isolation.
set -euo pipefail

_SOURCE="$0"
while [ -L "$_SOURCE" ]; do
    _DIR="$(cd -P "$(dirname "$_SOURCE")" && pwd)"
    _SOURCE="$(readlink "$_SOURCE")"
    [[ "$_SOURCE" != /* ]] && _SOURCE="$_DIR/$_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_SOURCE")" && pwd)"
unset _SOURCE _DIR
CCVM_YAML="${SCRIPT_DIR}/../config/lima/ccvm.yaml"
CCVM_PREFIX="ccvm"

# Dependency check
for cmd in limactl jq; do
    if ! command -v "$cmd" &>/dev/null; then
        echo "Error: '$cmd' is not installed. Run: brew install ${cmd/limactl/lima}" >&2
        exit 1
    fi
done

if [ ! -f "$CCVM_YAML" ]; then
    echo "Error: ccvm.yaml not found at $CCVM_YAML" >&2
    exit 1
fi

usage() {
    cat <<EOF
Usage:
  ccvm [--gh] [<workspace-path>]  Start Claude Code in a Lima VM
  ccvm list                       List ccvm VMs
  ccvm stop <name> [--all]        Stop a ccvm VM (or all with --all)
  ccvm delete <name> [--all]      Delete a ccvm VM (or all with --all)

Options:
  --gh    Mount ~/.config/gh (GitHub CLI auth) into the VM
EOF
}

# --- Helpers ---

resolve_workspace() {
    local target="${1:-.}"
    if [ ! -d "$target" ]; then
        echo "Error: workspace path does not exist or is not a directory: $target" >&2
        exit 1
    fi
    (cd "$target" && pwd)
}

# Deterministic VM name from workspace path (macOS only: uses md5 -q)
vm_name_from_path() {
    local hash
    hash=$(printf '%s' "$1" | md5 -q | cut -c1-4)
    echo "${CCVM_PREFIX}-$(basename "$1")-${hash}"
}

lima_query() {
    limactl list --json 2>/dev/null | jq -r "$@"
}

mount_opt() {
    echo ".mounts += [{\"location\": \"${1}\", \"mountPoint\": \"${2}\", \"writable\": ${3:-false}}]"
}

for_each_vm() {
    local filter="$1" count=0
    shift
    while IFS= read -r vm; do
        [ -n "$vm" ] || continue
        "$@" "$vm"
        ((count++))
    done < <(lima_query --arg prefix "${CCVM_PREFIX}-" "select(.name | startswith(\$prefix)) | ${filter}")
    if [ "$count" -eq 0 ]; then
        echo "No matching ccvm VMs found."
    fi
}

# --- Commands ---

cmd_list() {
    local output
    output="$(lima_query --arg prefix "${CCVM_PREFIX}-" \
        'select(.name | startswith($prefix)) | "\(.name)\t\(.status)\t\(.cpus)cpu\t\(.memory)"')"
    if [ -z "$output" ]; then
        echo "No ccvm VMs found. Create one with: ccvm <workspace-path>"
        return
    fi
    echo "$output"
}

cmd_stop() {
    if [ "${1:-}" = "--all" ]; then
        for_each_vm 'select(.status == "Running") | .name' limactl stop
        return
    fi
    local name="${1:?VM name required. Usage: ccvm stop <name>}"
    limactl stop "${CCVM_PREFIX}-${name}"
}

cmd_delete() {
    if [ "${1:-}" = "--all" ]; then
        for_each_vm '.name' _delete_vm
        return
    fi
    local name="${1:?VM name required. Usage: ccvm delete <name>}"
    _delete_vm "${CCVM_PREFIX}-${name}"
}

_delete_vm() {
    limactl stop "$1" 2>&1 || true
    limactl delete "$1" --force
}

cmd_start() {
    local mount_gh=false
    while [[ "${1:-}" == --* ]]; do
        case "$1" in
            --gh) mount_gh=true; shift ;;
            *) echo "Unknown option: $1"; usage; exit 1 ;;
        esac
    done

    local ws name
    ws="$(resolve_workspace "${1:-.}")"
    name="$(vm_name_from_path "$ws")"

    if ! lima_query -e --arg name "$name" 'select(.name == $name)' >/dev/null 2>&1; then
        echo "Creating VM $name..."
        local claude_config="${SCRIPT_DIR}/../config/claude"
        local claude_projects="${HOME}/.claude/projects"
        local set_args=(
            --set "$(mount_opt "$ws" /workspace true)"
            --set "$(mount_opt "$claude_config" /mnt/host-claude-config)"
            --set "$(mount_opt "$claude_projects" /mnt/host-claude-projects)"
        )
        if [ "$mount_gh" = true ]; then
            set_args+=(--set "$(mount_opt "${HOME}/.config/gh" /mnt/host-gh)")
        fi
        limactl create --name "$name" "${set_args[@]}" --tty=false "$CCVM_YAML"
        limactl start "$name"
    else
        local status
        status="$(lima_query --arg name "$name" 'select(.name == $name) | .status')"
        if [ "$status" != "Running" ]; then
            echo "Starting VM $name..."
            limactl start "$name"
        fi
    fi

    echo "Connecting to $name (workspace: $ws)..."
    limactl shell --workdir /workspace "$name" claude --dangerously-skip-permissions
}

# --- Main ---

case "${1:-}" in
    -h|--help|help) usage ;;
    list)   cmd_list ;;
    stop)   shift; cmd_stop "${@:+$@}" ;;
    delete) shift; cmd_delete "${@:+$@}" ;;
    *)      cmd_start "${@:+$@}" ;;
esac
