#!/bin/bash
# langfuse-setup - Claude Code のローカル可観測性セットアップ
#
# Langfuse 公式リポジトリを ~/.local/share/langfuse にクローンし
# docker compose で起動する。restart: always なので Rancher Desktop
# (dockerd) が起動していれば自動で復帰する。
#
# 参考: https://langfuse.com/self-hosting/docker-compose
#       https://langfuse.com/integrations/other/claude-code

set -euo pipefail

LANGFUSE_DIR="${LANGFUSE_DIR:-$HOME/.local/share/langfuse}"
LANGFUSE_REPO="${LANGFUSE_REPO:-https://github.com/langfuse/langfuse.git}"
LANGFUSE_VENV="${LANGFUSE_VENV:-$HOME/.claude/langfuse-venv}"

# シンボリックリンク経由で呼ばれた場合に実体のパスを解決する
_script="${BASH_SOURCE[0]}"
while [ -L "$_script" ]; do
    _script="$(readlink "$_script")"
done
DOTFILES_DIR="$(cd "$(dirname "$_script")/.." && pwd)"
ENV_TEMPLATE="$DOTFILES_DIR/config/langfuse/env.template"
ENV_FILE="$HOME/.claude/langfuse.env"

log() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$*" >&2; }
die() { printf '\033[1;31m[error]\033[0m %s\n' "$*" >&2; exit 1; }

# Dependency check
for cmd in git docker python3; do
    command -v "$cmd" >/dev/null 2>&1 || die "'$cmd' が見つかりません"
done
if ! docker compose version >/dev/null 2>&1; then
    die "'docker compose' が利用できません (Rancher Desktop が起動しているか確認)"
fi

# 1. clone / update langfuse repo
if [ -d "$LANGFUSE_DIR/.git" ]; then
    log "Langfuse リポジトリを更新: $LANGFUSE_DIR"
    git -C "$LANGFUSE_DIR" pull --ff-only
else
    log "Langfuse をクローン: $LANGFUSE_DIR"
    mkdir -p "$(dirname "$LANGFUSE_DIR")"
    git clone --depth 1 "$LANGFUSE_REPO" "$LANGFUSE_DIR"
fi

# 2. Langfuse hook 用の venv (公式 hook が `from langfuse import ...` するため)
if [ ! -x "$LANGFUSE_VENV/bin/python" ]; then
    log "venv を作成: $LANGFUSE_VENV"
    python3 -m venv "$LANGFUSE_VENV"
fi
log "langfuse SDK を venv にインストール / 更新"
"$LANGFUSE_VENV/bin/pip" install --quiet --upgrade pip
"$LANGFUSE_VENV/bin/pip" install --quiet --upgrade 'langfuse>=3'

# 3. env ファイルの用意 (dotfiles のテンプレートから ~/.claude/langfuse.env を生成)
if [ ! -f "$ENV_FILE" ]; then
    if [ ! -f "$ENV_TEMPLATE" ]; then
        die "テンプレートが見つかりません: $ENV_TEMPLATE"
    fi
    mkdir -p "$(dirname "$ENV_FILE")"
    cp "$ENV_TEMPLATE" "$ENV_FILE"
    chmod 600 "$ENV_FILE"
    log "env ファイルを作成: $ENV_FILE"
fi

# 4. docker compose up -d (restart: always により再起動後も自動復帰)
# LANGFUSE_INIT_* を docker compose に渡すため env ファイルを source する
# (初回起動時のゼロ設定シードに必要)
# shellcheck source=/dev/null
source "$ENV_FILE"
log "docker compose up -d ($LANGFUSE_DIR)"
(cd "$LANGFUSE_DIR" && docker compose up -d)

cat <<EOF

✅ Langfuse 起動完了

- UI:          http://localhost:3000
- env ファイル: $ENV_FILE
- リポジトリ:  $LANGFUSE_DIR
- hook venv:   $LANGFUSE_VENV

ログイン情報 (初期シード済み):
  URL:      http://localhost:3000
  Email:    me@local.dev
  Password: password

次のステップ:
  1. 新しい Claude Code セッションを起動 (zsh が env を読み込みトレースが開始)
  2. 任意: $ENV_FILE を編集してキーや設定をカスタマイズ

停止:   cd $LANGFUSE_DIR && docker compose down
更新:   $(basename "$0") (再実行で git pull + compose up + pip upgrade)
EOF
