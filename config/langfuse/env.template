# Langfuse 環境変数テンプレート
#
# bin/langfuse-setup がこのファイルを ~/.claude/langfuse.env にコピーし、
# config/zsh/langfuse.sh が shell 起動時に source する。
#
# ローカル Langfuse は localhost 限定のため pk-lf-local-* / sk-lf-local-* の
# ダミー値を直接埋め込んでおく (初回起動時に LANGFUSE_INIT_* で同じ値を
# シードするため、UI でのアカウント / API キー発行が不要になる)。
#
# 対応する環境変数は CC_LANGFUSE_* / LANGFUSE_* の 2 系統 (CC_* 優先)。
# 公式 hook が両方をサポートしているため、どちらで設定しても良い。

# ローカル Langfuse の URL (self-hosted)
export LANGFUSE_BASE_URL="http://localhost:3000"

# API キー (LANGFUSE_INIT_PROJECT_* と同じ値を使う)
export LANGFUSE_PUBLIC_KEY="pk-lf-local-1234"
export LANGFUSE_SECRET_KEY="sk-lf-local-5678"

# Claude Code の Stop hook が Langfuse に送信するかどうかのマスタースイッチ
export TRACE_TO_LANGFUSE="true"

# Langfuse 本体から Langfuse.com への使用統計送信を無効化
export TELEMETRY_ENABLED="false"

# 初回起動時に org / project / user / API keys を自動シード (UI 登録不要)
export LANGFUSE_INIT_ORG_ID="local-org"
export LANGFUSE_INIT_ORG_NAME="local"
export LANGFUSE_INIT_PROJECT_ID="claude-code-project"
export LANGFUSE_INIT_PROJECT_NAME="claude-code"
export LANGFUSE_INIT_PROJECT_PUBLIC_KEY="pk-lf-local-1234"
export LANGFUSE_INIT_PROJECT_SECRET_KEY="sk-lf-local-5678"
export LANGFUSE_INIT_USER_EMAIL="me@local.dev"
export LANGFUSE_INIT_USER_NAME="me"
export LANGFUSE_INIT_USER_PASSWORD="password"

# 任意: hook の debug ログ (~/.claude/state/langfuse_hook.log) を有効化
# export CC_LANGFUSE_DEBUG="true"

# 任意: 1 フィールドあたりの最大文字数 (デフォルト 20000)
# export CC_LANGFUSE_MAX_CHARS="20000"
